; ============================================================
;  NEXUS EA v2.0 - CONSERVATIVE preset
;  Recommended for accounts < $5,000 or low-risk strategy.
; ============================================================
InpRiskProfile=1
InpAutoScaleByAccount=true
InpUseSymbolWhitelist=true
InpAllowedSymbols=XAUUSD,EURUSD,USDJPY
InpHardMaxSpreadPts=0
InpOrderRetries=3
InpUseStatePersist=true
InpUseAtrTrail=true
InpAtrTrailMult=2.0
InpShowDashboard=true
