# ============================================================
# NEXUS self-hosted backend — configurazione
# Copia questo file in ".env" e cambia i valori.
# ============================================================

# Token condiviso EA <-> Backend <-> LocalBridge worker.
# DEVE essere identico a InpWebToken nell'EA e a bridge_token nel worker.
NEXUS_BRIDGE_TOKEN=NEXUS_BRIDGE_TOKEN_2026

# Credenziali per accedere alla dashboard web.
NEXUS_ADMIN_USER=admin
NEXUS_ADMIN_PASSWORD=cambia_questa_password

# Segreto per firmare i token di sessione della dashboard (JWT).
# Genera una stringa lunga e casuale.
NEXUS_JWT_SECRET=cambia_questo_segreto_lungo_e_casuale

# Durata sessione dashboard (ore).
NEXUS_JWT_HOURS=720

# Cookie di sessione "secure" (solo HTTPS). true su Render; metti false solo
# per test in locale via http.
NEXUS_COOKIE_SECURE=true

# Percorso del database SQLite (dentro al container è /data/nexus.db).
NEXUS_DB_PATH=/data/nexus.db

# (Opzionale) Notifiche Telegram. Se vuoti, i messaggi vengono solo loggati.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# (Opzionale) Licenza: se "open" ogni chiave è valida (utile self-hosted).
# Metti "strict" per validare solo le chiavi presenti nella tabella licenze.
NEXUS_LICENSE_MODE=open

# AI Coach — chiave API Claude (https://console.anthropic.com). Senza questa
# chiave il Coach risponde con un messaggio di "non disponibile".
ANTHROPIC_API_KEY=
# Modello usato dal Coach (claude-opus-4-8 o claude-sonnet-4-6).
NEXUS_COACH_MODEL=claude-opus-4-8
